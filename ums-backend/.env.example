# ─── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database (Supabase) ─────────────────────────────────────
# ⚠️  IMPORTANT: Use Transaction Pooler URL from Supabase Dashboard
# Go to: Project Settings → Database → Connection string → Transaction pooler
#
# Format:
#   postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#
# Your current URL (mask password before committing!):
#   postgresql://postgres.dledxkzhmlcawkhgwqfg:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
#
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:4200
