# ─── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database (Supabase) ───────────────────────────────────────
# วางค่าจาก Supabase Dashboard → Settings → Database → Transaction pooler
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ─── JWT ────────────────────────────────────────────────────────
JWT_SECRET=ums_local_jwt_secret_dev_2024
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=ums_local_refresh_secret_dev_2024
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ───────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:4200
